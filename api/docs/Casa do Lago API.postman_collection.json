{
  "info": {
    "name": "Casa do Lago API",
    "_postman_id": "casa-do-lago-collection",
    "description": "Collection completa para a API Casa do Lago — Auth, Clientes, Quartos, Reservas e Tags.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "token",   "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar usuário",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Silva\",\n  \"email\": \"joao@email.com\",\n  \"password\": \"senha123\",\n  \"confirmpassword\": \"senha123\",\n  \"telefone\": \"83999999999\",\n  \"cpf\": \"12345678901\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('Token salvo:', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao@email.com\",\n  \"password\": \"senha123\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Clientes",
      "item": [
        {
          "name": "Listar clientes (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/clientes", "host": ["{{baseUrl}}"], "path": ["clientes"] }
          },
          "response": []
        },
        {
          "name": "Buscar cliente por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/clientes/:id",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", ":id"],
              "variable": [{ "key": "id", "value": "CLIENTE_ID_AQUI" }]
            }
          },
          "response": []
        },
        {
          "name": "Atualizar cliente (próprio usuário)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/clientes/:id",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", ":id"],
              "variable": [{ "key": "id", "value": "SEU_CLIENTE_ID_AQUI" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"telefone\": \"83977777777\",\n  \"email\": \"novo@email.com\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Deletar cliente (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/clientes/:id",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", ":id"],
              "variable": [{ "key": "id", "value": "CLIENTE_ID_AQUI" }]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Quartos",
      "item": [
        {
          "name": "Listar quartos (público)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/quartos", "host": ["{{baseUrl}}"], "path": ["quartos"] }
          },
          "response": []
        },
        {
          "name": "Buscar quarto por ID (público)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/quartos/:id",
              "host": ["{{baseUrl}}"],
              "path": ["quartos", ":id"],
              "variable": [{ "key": "id", "value": "QUARTO_ID_AQUI" }]
            }
          },
          "response": []
        },
        {
          "name": "Criar quarto (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/quartos", "host": ["{{baseUrl}}"], "path": ["quartos"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Suíte Lago\",\n  \"fotos\": [\"https://exemplo.com/foto1.jpg\"],\n  \"valorDiaria\": 350\n}"
            }
          },
          "response": []
        },
        {
          "name": "Atualizar quarto (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/quartos/:id",
              "host": ["{{baseUrl}}"],
              "path": ["quartos", ":id"],
              "variable": [{ "key": "id", "value": "QUARTO_ID_AQUI" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"valorDiaria\": 400\n}"
            }
          },
          "response": []
        },
        {
          "name": "Deletar quarto (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/quartos/:id",
              "host": ["{{baseUrl}}"],
              "path": ["quartos", ":id"],
              "variable": [{ "key": "id", "value": "QUARTO_ID_AQUI" }]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Reservas",
      "item": [
        {
          "name": "Criar reserva",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/reservas", "host": ["{{baseUrl}}"], "path": ["reservas"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quartoId\": \"QUARTO_ID_AQUI\",\n  \"diaria\": {\n    \"dataInicio\": \"2026-04-01\",\n    \"dataFim\": \"2026-04-05\"\n  }\n}"
            }
          },
          "response": []
        },
        {
          "name": "Listar reservas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/reservas", "host": ["{{baseUrl}}"], "path": ["reservas"] }
          },
          "response": []
        },
        {
          "name": "Buscar reserva por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/reservas/:id",
              "host": ["{{baseUrl}}"],
              "path": ["reservas", ":id"],
              "variable": [{ "key": "id", "value": "RESERVA_ID_AQUI" }]
            }
          },
          "response": []
        },
        {
          "name": "Deletar reserva (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/reservas/:id",
              "host": ["{{baseUrl}}"],
              "path": ["reservas", ":id"],
              "variable": [{ "key": "id", "value": "RESERVA_ID_AQUI" }]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tags",
      "item": [
        {
          "name": "Listar tags (público)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/tags", "host": ["{{baseUrl}}"], "path": ["tags"] }
          },
          "response": []
        },
        {
          "name": "Listar quartos por tag (público)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tags/:id/quartos",
              "host": ["{{baseUrl}}"],
              "path": ["tags", ":id", "quartos"],
              "variable": [{ "key": "id", "value": "TAG_ID_AQUI" }]
            }
          },
          "response": []
        },
        {
          "name": "Criar tag (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/tags", "host": ["{{baseUrl}}"], "path": ["tags"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"piscina\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Adicionar tag ao quarto (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/tags/adicionar", "host": ["{{baseUrl}}"], "path": ["tags", "adicionar"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quartoId\": \"QUARTO_ID_AQUI\",\n  \"tagId\": \"TAG_ID_AQUI\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Remover tag do quarto (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/tags/remover", "host": ["{{baseUrl}}"], "path": ["tags", "remover"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quartoId\": \"QUARTO_ID_AQUI\",\n  \"tagId\": \"TAG_ID_AQUI\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Deletar tag (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/tags/:id",
              "host": ["{{baseUrl}}"],
              "path": ["tags", ":id"],
              "variable": [{ "key": "id", "value": "TAG_ID_AQUI" }]
            }
          },
          "response": []
        }
      ]
    }
  ]
}