# Credenciais do MongoDB Atlas
DB_USER=seu_usuario_mongodb
DB_PASS=sua_senha_mongodb

# Chave secreta para assinar os tokens JWT (use uma string longa e aleatória)
SECRET=sua_chave_secreta_jwt_muito_segura

# URL do frontend no Vercel (usado pelo CORS)
# Ex: https://casa-do-lago.vercel.app
FRONTEND_URL=https://seu-projeto.vercel.app

# Porta local (opcional — o Render define automaticamente)
# PORT=3000
